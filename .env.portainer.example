# Portainer-ready environment example
# Copy this file to `.env` or paste these variables into Portainer's "Deploy a stack" environment section.
# Do NOT commit secrets to a public repo. Replace placeholder values before deploying.

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme_secure_password
MONGO_INITDB_DATABASE=agrinova_db

# If you want to provide a full URI instead of the separate MONGO_* vars,
# set MONGODB_URI. When using the internal Docker network use the service name `mongodb`.
# Example: mongodb://admin:changeme_secure_password@mongodb:27017/agrinova_db?authSource=admin
MONGODB_URI=mongodb://admin:changeme_secure_password@mongodb:27017/agrinova_db?authSource=admin

# --- Backend / App ---
BACKEND_PORT=5000
# HOST_PORT=10011   # OPTIONAL: uncomment to expose backend on host port (default: internal only)
JWT_SECRET=replace_with_a_long_random_secret
FRONTEND_URL=https://your-production-domain.example
GEMINI_API_KEY=        # optional; leave empty if not used

# --- Frontend & Proxy ---
FRONTEND_PORT=10009
PROXY_PORT=10010

# --- Bind mounts (example TrueNAS/production paths) ---
# Portainer will deploy on your host — set this to your TrueNAS dataset path for persistent data.
MOUNT_ROOT=/mnt/tank/docker-data
# Compose uses the following bind mounts by default:
# ${MOUNT_ROOT}/mongodb:/data/db
# ${MOUNT_ROOT}/backend/logs:/usr/src/app/logs
# ${MOUNT_ROOT}/backend/uploads:/usr/src/app/uploads
# ${MOUNT_ROOT}/frontend/logs:/var/log/nginx
# ${MOUNT_ROOT}/nginx/conf.d:/etc/nginx/conf.d (required for proxy service)
#
# SETUP INSTRUCTIONS FOR PORTAINER:
# Before deploying, copy these nginx configs to your host:
#   mkdir -p /mnt/tank/docker-data/nginx/conf.d
#   cat > /mnt/tank/docker-data/nginx/conf.d/default.conf << 'EOF'
#   server {
#     listen 80;
#     server_name _;
#     location / {
#       proxy_pass http://agrinova_frontend;
#       proxy_set_header Host $host;
#       proxy_set_header X-Real-IP $remote_addr;
#       proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#       proxy_set_header X-Forwarded-Proto $scheme;
#     }
#     access_log /var/log/nginx/access.log;
#     error_log /var/log/nginx/error.log;
#   }
#   EOF

# --- Optional tuning ---
# Set these to tune healthcheck/startup behavior in environments that are slow to start
MONGO_STARTUP_RETRIES=30
MONGO_STARTUP_DELAY=2

# --- Notes ---
# 1) When deploying from Git in Portainer, either (a) paste these variables into the
#    Stack > Environment section, or (b) use this file as a template and upload a private
#    .env file to the host before deploying. Do NOT commit your real .env to the repo.
# 2) If you prefer using Docker secrets, create secrets in Portainer and update the
#    compose file to read secrets instead of exposing plaintext env vars.
